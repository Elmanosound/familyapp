# ============================================================
#  FamilyApp — Fichier d'exemple (server/.env)
#  Copiez ce fichier vers server/.env et adaptez les valeurs.
# ============================================================

# ─── Serveur ────────────────────────────────────────────────
# Port d'ecoute de l'API Express (doit correspondre au proxy Vite)
PORT=5000
# development | production | test
NODE_ENV=development
# URL du client (CORS + redirections email)
CLIENT_URL=http://localhost:5173

# ─── Base de donnees ────────────────────────────────────────
# Option A — SQLite (par defaut, aucun service externe requis)
#   Le fichier dev.db sera cree dans server/prisma/.
DATABASE_URL=file:./dev.db
#
# Option B — PostgreSQL local
#   1) Installez PostgreSQL 14+ (pgAdmin inclus)
#   2) Creez la base : CREATE DATABASE familyapp;
#   3) Dans server/prisma/schema.prisma, remplacez provider = "sqlite"
#      par provider = "postgresql"
#   4) Remplacez la ligne DATABASE_URL ci-dessus par :
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/familyapp

# ─── JWT ────────────────────────────────────────────────────
# IMPORTANT : en production, remplacez par des chaines aleatoires longues
# (ex : `openssl rand -base64 48`)
JWT_SECRET=change-this-to-a-long-random-string
JWT_REFRESH_SECRET=change-this-to-another-long-random-string
# Duree de vie du token d'acces (format ms : 15m, 1h, 1d)
JWT_EXPIRES_IN=15m
# Duree de vie du refresh token
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cloudinary (upload photos/videos) ──────────────────────
# Optionnel en developpement. Sans ces cles, l'upload de media echouera
# mais les autres modules (auth, calendrier, listes, chat...) fonctionnent.
# Creez un compte gratuit sur https://cloudinary.com puis copiez les cles
# depuis le Dashboard.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email SMTP (reinitialisation de mot de passe, invitations) ─
# Optionnel en developpement. Les envois d'email seront simplement ignores.
# Exemple Gmail : activez la double authentification puis generez un
# "mot de passe d'application" sur https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Client (optionnel, uniquement si vous changez les URLs par defaut) ─
# Ces variables sont lues par Vite. Elles doivent etre definies dans
# client/.env.local si vous souhaitez les surcharger.
# VITE_API_URL=http://localhost:5000/api/v1
# VITE_SOCKET_URL=http://localhost:5000
