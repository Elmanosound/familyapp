# ============================================================
#  FamilyApp — Caddy reverse proxy
#
#  Provides automatic HTTPS via Let's Encrypt.
#  Requires:
#    - A valid public domain pointing to this server's IP
#    - Ports 80 and 443 open in the firewall / GCP security rules
#    - DOMAIN set in .env  (e.g. DOMAIN=family.example.com)
#
#  Caddy handles:
#    - TLS certificate issuance and renewal (automatic)
#    - HTTP → HTTPS redirect (automatic)
#    - Security headers (HSTS, CSP, X-Frame-Options, …)
#    - WebSocket proxying for Socket.IO (transparent)
#    - gzip compression
# ============================================================

{$DOMAIN} {

    # ── Reverse proxy ─────────────────────────────────────────
    reverse_proxy app:8080 {
        # Forward real client info to the Node.js app
        header_up Host              {host}
        header_up X-Real-IP         {remote_host}
        header_up X-Forwarded-For   {remote_host}
        header_up X-Forwarded-Proto {scheme}

        # Flush immediately — required for SSE and WebSocket streaming
        flush_interval -1

        # Keep connections alive long enough for Socket.IO heartbeats
        # (Socket.IO default ping interval: 25 s, timeout: 20 s)
        transport http {
            keepalive            90s
            keepalive_idle_conns 16
        }
    }

    # ── Compression ───────────────────────────────────────────
    encode gzip

    # ── Security headers ──────────────────────────────────────
    header {
        # Remove server fingerprinting
        -Server

        # Force HTTPS for 1 year, include subdomains
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

        # Prevent embedding in iframes (clickjacking)
        X-Frame-Options "SAMEORIGIN"

        # Prevent MIME-type sniffing
        X-Content-Type-Options "nosniff"

        # Limit referrer information
        Referrer-Policy "strict-origin-when-cross-origin"

        # Restrict browser features
        Permissions-Policy "geolocation=(self), camera=(self), microphone=()"

        # ── Content-Security-Policy ────────────────────────────
        #
        # script-src 'self'         Vite bundles all JS to /assets/*.js —
        #                           no inline scripts needed in production.
        #                           Blocks injected <script> tags (XSS).
        #
        # style-src 'unsafe-inline' Required for CSS-in-JS and styles
        #                           injected by UI libraries at runtime.
        #                           Google Fonts CSS served from its CDN.
        #
        # img-src / media-src       'self' for /uploads, Cloudinary for
        #                           hosted photos & videos, data:/blob:
        #                           for in-memory previews before upload.
        #
        # connect-src 'self'        Covers same-origin API calls and
        #                           Socket.IO WebSocket (wss://same-domain).
        #                           Cloudinary API for server-side uploads.
        #
        # frame-ancestors 'none'    Blocks all framing (redundant with
        #                           X-Frame-Options, but CSP takes precedence
        #                           in modern browsers).
        #
        Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https://res.cloudinary.com; connect-src 'self' https://api.cloudinary.com; media-src 'self' https://res.cloudinary.com blob:; worker-src blob:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests;"
    }

    # ── Access logs ───────────────────────────────────────────
    log {
        output file /data/logs/access.log {
            roll_size    10MiB
            roll_keep    7
            roll_keep_for 168h  # 7 days
        }
        format json
    }
}
