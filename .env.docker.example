# ============================================================
#  FamilyApp — Docker Compose environment template
#  Copy to .env (in the repo root) and fill the required values.
#
#    cp .env.docker.example .env
#
#  Then start the stack with:
#    docker compose up -d
# ============================================================

# ─── Required ───────────────────────────────────────────────
# Postgres credentials (will create the database on first boot)
POSTGRES_DB=familyapp
POSTGRES_USER=familyapp
POSTGRES_PASSWORD=change-me-to-a-strong-password

# JWT secrets — generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=replace-me-with-another-long-random-string

# ─── Optional ───────────────────────────────────────────────
# Token lifetimes
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Public host port (defaults to 8080)
APP_PORT=8080

# Public URL — used for CORS and links inside emails.
# In production, set to your domain e.g. https://family.example.com
CLIENT_URL=http://localhost:8080

# ─── Cloudinary (photos/videos) — optional ──────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── SMTP (password reset / invitations) — optional ─────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Caddy reverse proxy (only if you uncomment caddy in compose) ─
# DOMAIN=family.example.com
