# ============================================================
#  FamilyApp — Docker Compose environment template
#
#  Copy to .env and fill the required values:
#    cp .env.docker.example .env
#
#  ── HTTP mode (dev / LAN) ───────────────────────────────────
#    Fill the Required section below, then:
#    docker compose up -d
#
#  ── HTTPS mode (production) ─────────────────────────────────
#    Fill everything below including the HTTPS section, then:
#    docker compose --profile https up -d
#    (or just ./deploy.sh — it detects DOMAIN automatically)
# ============================================================

# ─── Required ───────────────────────────────────────────────

# PostgreSQL credentials (the DB is created on first boot)
POSTGRES_DB=familyapp
POSTGRES_USER=familyapp
POSTGRES_PASSWORD=change-me-to-a-strong-password

# JWT secrets — generate unique values with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=replace-me-with-another-long-random-string

# ─── HTTPS (production) ─────────────────────────────────────
# Set these when using the Caddy reverse proxy (--profile https).
# Leave commented out for HTTP-only mode.

# Your fully qualified domain name (DNS A record must point here)
# DOMAIN=family.example.com

# Must match the DOMAIN above (used for CORS + email links)
# CLIENT_URL=https://family.example.com

# Bind the app port to loopback only — Caddy proxies from outside.
# Remove or set to "8080" for direct HTTP access without Caddy.
# APP_PORT=127.0.0.1:8080

# ─── Optional ───────────────────────────────────────────────

# Token lifetimes
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Public URL for HTTP mode (CORS + email links)
# In HTTPS mode this is replaced by CLIENT_URL above.
CLIENT_URL=http://localhost:8080

# Direct host port — only used in HTTP mode (no Caddy).
# Set to 127.0.0.1:8080 when Caddy is active (see HTTPS section above).
APP_PORT=8080

# ─── Cloudinary (photos / videos upload) — optional ─────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── SMTP (password reset / invitations) — optional ─────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
